NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

HERMES_URL=http://hermes-agent:8642
HERMES_API_KEY=your-api-server-key
NEXT_PUBLIC_APP_URL=http://localhost:3000

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Optional fallback if Hermes Telegram is not configured
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Run limits per user (disabled by default)
DAILY_RUN_LIMIT=1
ENFORCE_DAILY_LIMIT=true
MONTHLY_RUN_LIMIT=5
ENFORCE_MONTHLY_LIMIT=true

# Set to 1 to log all Hermes SSE payloads in the server terminal (not browser console)
STREAM_DEBUG=0
# Optional: cap how many payloads to log (omit for unlimited when STREAM_DEBUG=1)
# STREAM_DEBUG_LIMIT=50
# Optional: log full payload JSON instead of 500-char preview
# STREAM_DEBUG_FULL=1
